; Townling game client — Godot 4 project.
; Low-poly 3D hub-and-card game on a fixed isometric camera (design doc §18).
; Rendered with GL Compatibility so the HTML5 web export runs everywhere.

config_version=5

[application]

config/name="Townling"
config/description="A privacy-first, ad-free financial life-simulation game for children."
run/main_scene="res://scenes/diorama.tscn"
config/features=PackedStringArray("4.4", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Sfx="*res://scripts/audio.gd"
GameState="*res://scripts/game_state.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[gui]

theme/custom_font="res://assets/kenney/fonts/lilita_one_regular.ttf"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.968627, 0.964706, 0.94902, 1)
; Smoothness: 4x MSAA (supported by gl_compatibility/WebGL2) + soft shadows.
anti_aliasing/quality/msaa_3d=2
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=3
lights_and_shadows/directional_shadow/size=4096
