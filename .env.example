# Copy to .env and adjust. `make up` reads .env.
# None of these are secrets in dev; set real values before any deployment.

# --- Django ---
DJANGO_SECRET_KEY=dev-insecure-change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend
# Dev-permissive CORS so the Godot web client (:8080) can call the API (:8000).
DJANGO_CORS_ALLOW_ALL=true

# --- Game (Godot web export) ---
# Pin the Godot version used for the headless HTML5 export.
GODOT_VERSION=4.4.1
# Backend URL the web client calls (written into /config.json at container start).
# Point this at your deployed API in other environments; no rebuild needed.
TOWNLING_API_BASE=http://localhost:8000
